{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "ACCELERATE_DATABASE_URL",
        "DIRECT_DATABASE_URL",
        "PORT",
        "AUTH0_SECRET",
        "AUTH0_BASE_URL",
        "AUTH0_ISSUER_BASE_URL",
        "AUTH0_CLIENT_ID",
        "AUTH0_CLIENT_SECRET",
        "AUTH0_DOMAIN",
        "APP_BASE_URL",
        "AUTH0_ADMIN_SUBS",
        "AUTH0_MCP_AUDIENCE",
        "META_MODEL_API_KEY",
        "STEVEN_AGENT_PRIVATE_MODEL_ENABLED",
        "STEVEN_AGENT_PUBLIC_MODEL_ENABLED",
        "STEVEN_AGENT_VISITOR_SECRET",
        "VOYAGE_API_KEY"
      ],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "deploy": {
      "dependsOn": ["build", "test", "lint"]
    },
    "test": {
      "dependsOn": ["build"],

      "inputs": ["src/**/*.tsx", "src/**/*.ts", "test/**/*.ts", "test/**/*.tsx"]
    },

    "lint": {},
    "dev": {
      "cache": false,
      "persistent": false
    }
  }
}
