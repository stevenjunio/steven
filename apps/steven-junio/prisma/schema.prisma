// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//define a blog post model
model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String?
  slug      String?  @unique
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  author    User?    @relation(fields: [authorId], references: [id])
  authorId  Int?
}

//define a user model
model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
  posts Post[]
}

enum AgentScope {
  PUBLIC
  PRIVATE
  NEVER_PUBLISH
}

enum KnowledgeRevisionStatus {
  DRAFT
  READY
  ARCHIVED
}

enum KnowledgeReleaseStatus {
  DRAFT
  PUBLISHED
  RETIRED
}

enum MemoryCandidateStatus {
  PROPOSED
  APPROVED
  REJECTED
}

enum AgentMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum AgentRunStatus {
  RESERVED
  SUCCEEDED
  FAILED
  REJECTED
}

enum UsageWindow {
  MINUTE
  DAY
  MONTH
}

enum UsageLedgerKind {
  RESERVE
  COMMIT
  RELEASE
  ADJUSTMENT
}

model KnowledgeSource {
  id          String              @id @default(cuid())
  name        String
  kind        String
  scope       AgentScope
  modelAccess Boolean             @default(true)
  sourceUrl   String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  revisions   KnowledgeRevision[]

  @@unique([id, scope])
  @@index([scope, updatedAt])
}

model KnowledgeRevision {
  id          String                  @id @default(cuid())
  sourceId    String
  scope       AgentScope
  version     Int
  content     String
  checksum    String
  status      KnowledgeRevisionStatus @default(DRAFT)
  createdAt   DateTime                @default(now())
  publishedAt DateTime?
  source      KnowledgeSource         @relation(fields: [sourceId, scope], references: [id, scope], onDelete: Cascade)
  chunks      KnowledgeChunk[]

  @@unique([sourceId, version])
  @@unique([id, scope])
  @@index([status, publishedAt])
}

model KnowledgeChunk {
  id           String                 @id @default(cuid())
  revisionId   String
  scope        AgentScope
  ordinal      Int
  content      String
  tokenCount   Int
  embedding    Json?
  metadata     Json?
  createdAt    DateTime               @default(now())
  revision     KnowledgeRevision      @relation(fields: [revisionId, scope], references: [id, scope], onDelete: Cascade)
  releaseItems KnowledgeReleaseItem[]

  @@unique([revisionId, ordinal])
  @@index([scope, createdAt])
}

model KnowledgeRelease {
  id          String                 @id @default(cuid())
  name        String
  status      KnowledgeReleaseStatus @default(DRAFT)
  createdAt   DateTime               @default(now())
  publishedAt DateTime?
  retiredAt   DateTime?
  items       KnowledgeReleaseItem[]

  @@index([status, publishedAt])
}

model KnowledgeReleaseItem {
  releaseId String
  chunkId   String
  release   KnowledgeRelease @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  chunk     KnowledgeChunk   @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@id([releaseId, chunkId])
  @@index([chunkId])
}

model PersonaVersion {
  id           String     @id @default(cuid())
  scope        AgentScope
  version      Int
  instructions String
  active       Boolean    @default(false)
  createdAt    DateTime   @default(now())
  activatedAt  DateTime?

  @@unique([scope, version])
  @@index([scope, active])
}

model MemoryCandidate {
  id            String                @id @default(cuid())
  scope         AgentScope
  content       String
  evidence      Json?
  status        MemoryCandidateStatus @default(PROPOSED)
  createdAt     DateTime              @default(now())
  reviewedAt    DateTime?
  reviewedBySub String?
  approvedFact  MemoryFact?

  @@index([status, createdAt])
}

model MemoryFact {
  id                String           @id @default(cuid())
  scope             AgentScope
  content           String
  sourceCandidateId String?          @unique
  createdAt         DateTime         @default(now())
  archivedAt        DateTime?
  sourceCandidate   MemoryCandidate? @relation(fields: [sourceCandidateId], references: [id], onDelete: SetNull)

  @@index([scope, archivedAt])
}

model AgentConversation {
  id        String         @id @default(cuid())
  scope     AgentScope
  visitorId String?
  ownerSub  String?
  title     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?
  messages  AgentMessage[]
  runs      AgentRun[]

  @@index([scope, visitorId, updatedAt])
  @@index([ownerSub, updatedAt])
}

model AgentMessage {
  id             String            @id @default(cuid())
  conversationId String
  role           AgentMessageRole
  content        String
  citations      Json?
  createdAt      DateTime          @default(now())
  conversation   AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model AgentRun {
  id                  String            @id @default(cuid())
  conversationId      String
  scope               AgentScope
  provider            String
  model               String
  status              AgentRunStatus    @default(RESERVED)
  estimatedCostMicros BigInt
  actualCostMicros    BigInt?
  inputTokens         Int?
  cachedInputTokens   Int?
  outputTokens        Int?
  reasoningTokens     Int?
  errorCode           String?
  durationMs          Int?
  createdAt           DateTime          @default(now())
  completedAt         DateTime?
  conversation        AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  usageLedger         UsageLedger[]

  @@index([scope, createdAt])
  @@index([conversationId, createdAt])
}

model UsageBucket {
  id             String        @id @default(cuid())
  scope          AgentScope
  key            String
  window         UsageWindow
  periodStart    DateTime
  periodEnd      DateTime
  requestCount   Int           @default(0)
  reservedMicros BigInt        @default(0)
  spentMicros    BigInt        @default(0)
  activeCount    Int           @default(0)
  updatedAt      DateTime      @updatedAt
  ledger         UsageLedger[]

  @@unique([scope, key, window, periodStart])
  @@index([scope, window, periodEnd])
}

model UsageLedger {
  id           String          @id @default(cuid())
  bucketId     String
  runId        String?
  requestId    String
  kind         UsageLedgerKind
  costMicros   BigInt
  inputTokens  Int             @default(0)
  outputTokens Int             @default(0)
  metadata     Json?
  createdAt    DateTime        @default(now())
  bucket       UsageBucket     @relation(fields: [bucketId], references: [id], onDelete: Restrict)
  run          AgentRun?       @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@unique([bucketId, requestId, kind])
  @@index([runId])
  @@index([createdAt])
}

model AuditEvent {
  id         String      @id @default(cuid())
  actorSub   String?
  action     String
  entityType String
  entityId   String?
  scope      AgentScope?
  metadata   Json?
  createdAt  DateTime    @default(now())

  @@index([action, createdAt])
  @@index([scope, createdAt])
}
