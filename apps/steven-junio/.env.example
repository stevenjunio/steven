# Database
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
ACCELERATE_DATABASE_URL=prisma://accelerate.prisma-data.net/?api_key=REPLACE_ME

# Auth0 web application
AUTH0_DOMAIN=tenant.us.auth0.com
AUTH0_CLIENT_ID=REPLACE_ME
AUTH0_CLIENT_SECRET=REPLACE_ME
AUTH0_SECRET=generate-at-least-32-random-bytes
APP_BASE_URL=http://localhost:3000
AUTH0_ADMIN_SUBS=auth0|replace-with-stevens-immutable-user-subject

# Muse Spark 1.1
META_MODEL_API_KEY=REPLACE_ME
# Keep false until paid-provider retention/training terms are approved.
STEVEN_AGENT_PRIVATE_MODEL_ENABLED=false

# Visitor abuse protection. Use an independent random value of at least 32 bytes.
STEVEN_AGENT_VISITOR_SECRET=generate-an-independent-32-byte-secret

# Optional semantic retrieval. Lexical retrieval works without this.
VOYAGE_API_KEY=REPLACE_ME

# Auth0 API configured for the owner-only MCP resource.
AUTH0_MCP_AUDIENCE=https://www.stevenjunio.com/mcp
